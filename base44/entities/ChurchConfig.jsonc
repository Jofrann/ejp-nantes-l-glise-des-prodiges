{
  "name": "ChurchConfig",
  "type": "object",
  "properties": {
    "hero_video_url": {
      "type": "string",
      "description": "URL de la vid\u00e9o h\u00e9ro"
    },
    "hero_title": {
      "type": "string",
      "description": "Titre principal"
    },
    "hero_subtitle": {
      "type": "string",
      "description": "Sous-titre"
    },
    "vision_title": {
      "type": "string",
      "description": "Titre de la section Vision"
    },
    "vision_text": {
      "type": "string",
      "description": "Texte de la vision"
    },
    "service_day": {
      "type": "string",
      "description": "Jour du culte",
      "default": "Dimanche"
    },
    "service_time": {
      "type": "string",
      "description": "Heure du culte (HH:MM)",
      "default": "15:00"
    },
    "address_label": {
      "type": "string",
      "description": "Adresse lisible"
    },
    "maps_link": {
      "type": "string",
      "description": "Lien Google Maps"
    },
    "contact_email": {
      "type": "string",
      "description": "Email de contact"
    },
    "instagram_url": {
      "type": "string",
      "description": "Lien Instagram"
    },
    "youtube_url": {
      "type": "string",
      "description": "Lien YouTube"
    },
    "whatsapp_url": {
      "type": "string",
      "description": "Lien WhatsApp"
    },
    "tiktok_url": {
      "type": "string",
      "description": "Lien TikTok"
    },
    "announcement_text": {
      "type": "string",
      "description": "Texte de l'annonce"
    },
    "announcement_active": {
      "type": "boolean",
      "description": "Afficher l'annonce ?",
      "default": false
    }
  },
  "required": [
    "hero_title"
  ]
}